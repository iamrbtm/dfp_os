{
  "name": "dfp-os",
  "version": "0.1.0",
  "private": true,
  "description": "Tailwind asset pipeline for Dude Fish OS.",
  "scripts": {
    "build:css": "tailwindcss -i ./app/static/src/input.css -o ./app/static/dist/app.css --minify",
    "build:js": "mkdir -p ./app/static/dist/vendor && cp ./node_modules/gsap/dist/gsap.min.js ./app/static/dist/vendor/gsap.min.js && cp ./node_modules/gsap/dist/ScrollTrigger.min.js ./app/static/dist/vendor/ScrollTrigger.min.js",
    "build": "npm run build:css && npm run build:js",
    "watch:css": "tailwindcss -i ./app/static/src/input.css -o ./app/static/dist/app.css --watch",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17"
  },
  "dependencies": {
    "@opencode-ai/models": "^0.0.7",
    "gsap": "^3.15.0"
  }
}
