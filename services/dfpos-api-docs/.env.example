# Where to fetch the OpenAPI spec from the main DFP OS app
DFPOS_OPENAPI_URL=http://web:5000/api/openapi.json

# Fallback local spec path (used when DFPOS_OPENAPI_URL is unreachable)
DFPOS_OPENAPI_FALLBACK_PATH=./openapi/openapi.json

# How often to refresh the spec from the source URL (seconds, 0 = disabled)
DFPOS_OPENAPI_REFRESH_INTERVAL=300

# Server configuration
HOST=0.0.0.0
PORT=8080

# Enable basic auth for the docs site (default: no auth)
# DOCS_USERNAME=admin
# DOCS_PASSWORD=change-me

# Comma-separated list of paths to require auth for
# Leave empty to allow public access
DOCS_AUTH_REQUIRED_PATHS=/private

# Flask secret key (used for sessions if auth is enabled)
SECRET_KEY=change-me-docs-secret

# Application name shown in the docs header
APP_NAME=Dude Fish OS API Reference

# Redoc theme: light, dark, or custom JSON
REDOC_THEME=light

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
