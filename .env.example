FLASK_ENV=development
SECRET_KEY=change-me
DATABASE_URL=mysql+pymysql://username:password@localhost:3306/dudefish_os
TEST_DATABASE_URL=mysql+pymysql://username:password@localhost:3306/dudefish_os_test
TEST_DATABASE_ADMIN_URL=mysql+pymysql://root:rootpassword@localhost:3306/mysql
MARIADB_DATABASE=dudefish_os
MARIADB_USER=username
MARIADB_PASSWORD=password
MARIADB_ROOT_PASSWORD=rootpassword
APP_NAME=Dude Fish OS
APP_BASE_URL=http://localhost:5000
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-now
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH_MB=16
POS_CARD_PROCESSING_ENABLED=false
POS_CARD_PROCESSOR=placeholder
WEATHER_USER_AGENT=Dude Fish OS (admin@example.com)

# Receipt Management
FILE_STORAGE_BACKEND=local
RECEIPT_STORAGE_DRIVER=local
RECEIPT_STORAGE_PATH=uploads/receipts
MARKET_DOCUMENTS_PATH=uploads/markets
PRODUCT_ASSETS_PATH=uploads/products
S3_ENDPOINT_URL=http://seaweedfs:8333
S3_REGION=us-east-1
S3_ACCESS_KEY=change-me-access-key
S3_SECRET_KEY=change-me-secret-key
S3_USE_SSL=false
S3_AUTO_CREATE_BUCKETS=true
RECEIPT_STORAGE_BUCKET=receipts
MARKET_DOCUMENTS_BUCKET=markets
PRODUCT_ASSETS_BUCKET=products
RECEIPT_MAX_UPLOAD_MB=25
RECEIPT_ALLOWED_TYPES=image/jpeg,image/png,image/heic,image/heif,application/pdf
RECEIPT_OCR_PROVIDER=tesseract
RECEIPT_AI_PROVIDER=openai
OPENAI_API_KEY=change-me
OPENAI_MODEL=gpt-4o-mini
OPENAI_MODEL_RECEIPTS=gpt-4o-mini
OPENAI_MODEL_ANALYTICS=gpt-4o-mini
OPENAI_MODEL_TREND_SCOUT=gpt-4o-mini
ETSY_API_KEY=
PINTEREST_API_KEY=
SERPAPI_API_KEY=
TIKTOK_RESEARCH_ACCESS_TOKEN=
AI_RECEIPT_PARSING_ENABLED=false
AI_ANALYTICS_INSIGHTS_ENABLED=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_FALLBACK_URL=http://localhost:11434
OLLAMA_RECEIPT_MODEL=llama3
RECEIPT_ENABLE_API_FALLBACK=false
RECEIPT_API_PROVIDER=
TAGGUN_API_KEY=
MINDEE_API_KEY=
VERYFI_CLIENT_ID=
VERYFI_CLIENT_SECRET=
RECEIPT_DUPLICATE_STRICTNESS=normal
RECEIPT_LOW_CONFIDENCE_THRESHOLD=0.80

# Celery / Background Tasks
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Audit Log Microservice
AUDIT_LOG_BASE_URL=http://audit-log-service:8090
AUDIT_LOG_TOKEN=change-me-audit-token
AUDIT_LOG_ENABLED=false
AUDIT_LOG_FAIL_CLOSED=false
AUDIT_LOG_FAIL_CLOSED_FOR_FINANCIAL_ACTIONS=false
ALLOW_NEGATIVE_INVENTORY=false
RATE_LIMIT_ENABLED=true
LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=60
API_AUTH_RATE_LIMIT_ATTEMPTS=60
API_AUTH_RATE_LIMIT_WINDOW_SECONDS=60

# Intelligence Microservice
INTELLIGENCE_ENABLED=true
INTELLIGENCE_SERVICE_URL=http://intelligence:8091
INTELLIGENCE_INTERNAL_API_TOKEN=change-me-intelligence-token
INTELLIGENCE_DATABASE_URL=postgresql+asyncpg://dfp_intelligence:dfp_intelligence_password@localhost:5433/dfp_intelligence
INTELLIGENCE_POSTGRES_DB=dfp_intelligence
INTELLIGENCE_POSTGRES_USER=dfp_intelligence
INTELLIGENCE_POSTGRES_PASSWORD=change-me-intelligence-db
INTELLIGENCE_AUDIT_LOG_BASE_URL=http://audit-log-service:8090
INTELLIGENCE_AUDIT_LOG_TOKEN=change-me-audit-token
INTELLIGENCE_AUDIT_LOG_ENABLED=false
INTELLIGENCE_LEGACY_MARIADB_HOST=
INTELLIGENCE_LEGACY_MARIADB_PORT=3306
INTELLIGENCE_LEGACY_MARIADB_DATABASE=
INTELLIGENCE_LEGACY_MARIADB_USER=
INTELLIGENCE_LEGACY_MARIADB_PASSWORD=

# Audit Log database used by docker-compose.yml
AUDIT_POSTGRES_DB=dfp_audit
AUDIT_POSTGRES_USER=dfp_audit
AUDIT_POSTGRES_PASSWORD=change-me-audit-db
AUDIT_HASH_SECRET=change-me-audit-hash-secret

# Optional API docs service, used with docker compose --profile docs
DOCS_USERNAME=docs-admin
DOCS_PASSWORD=change-me-docs-password
DOCS_AUTH_REQUIRED=true
